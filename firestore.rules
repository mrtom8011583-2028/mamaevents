rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Existing rules for quotes (assuming logic based on your error)
    match /quote_requests/{quoteId} {
      allow create: if true;
      allow read, update: if request.auth != null; // Admin only usually
    }

    // NEW: Verification Codes
    match /verification_codes/{codeId} {
      // Allow creation by anyone (guest users)
      allow create: if true;
      
      // Allow reading only if checking a specific code (could be refined)
      // or by admins
      allow read: if true;
      
      // Allow updating (marking as verified)
      allow update: if true;
    }
    
    // Admin Notifications
    match /admin_notifications/{notificationId} {
       allow read, write: if request.auth != null;
    }
    
    // Default catch-all (usually deny)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
